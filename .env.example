# Copy this file to `.env` (in the project root) and fill in real values.
# The backend (server/index.js) reads these at startup.

PORT=5179

# ─── SMTP credentials ─────────────────────────────────────────────────────
# Examples:
#   Gmail (use an "App password", NOT your normal password):
#     SMTP_HOST=smtp.gmail.com
#     SMTP_PORT=587
#     SMTP_USER=youraddress@gmail.com
#     SMTP_PASS=your-16-char-app-password
#
#   Outlook / Hotmail:
#     SMTP_HOST=smtp.office365.com
#     SMTP_PORT=587
#
#   SendGrid:
#     SMTP_HOST=smtp.sendgrid.net
#     SMTP_PORT=587
#     SMTP_USER=apikey
#     SMTP_PASS=<your SendGrid API key>
#
#   Mailtrap (great for local testing — emails are caught, not delivered):
#     SMTP_HOST=sandbox.smtp.mailtrap.io
#     SMTP_PORT=2525
#     SMTP_USER=<from your mailtrap inbox>
#     SMTP_PASS=<from your mailtrap inbox>

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Friendly From: header (optional)
MAIL_FROM="Jiraly <no-reply@example.com>"

# ─── Google Sign-In ───────────────────────────────────────────────────────
# Create an OAuth 2.0 *Web application* Client ID at:
#   https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins must include:
#   http://localhost:5173
#   http://localhost:5174
# Then paste the client ID below. Both names accept the same value — the
# backend reads GOOGLE_CLIENT_ID, the frontend reads VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=803528686790-gde2f9ceop35cbgipbhtf4fkdlrd9445.
VITE_GOOGLE_CLIENT_ID=
