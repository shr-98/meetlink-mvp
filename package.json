{
  "name": "meetlink-mvp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Lightweight meeting link manager for teams — localStorage MVP",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "server:py": "cd server_py && ./.venv/bin/python app.py",
    "server:py:setup": "cd server_py && python3 -m venv .venv && ./.venv/bin/pip install -r requirements.txt",
    "freeports": "lsof -ti :5173 -ti :5179 | xargs kill -9 2>/dev/null; true",
    "predev:all": "npm run freeports",
    "predev:py": "npm run freeports",
    "dev:all": "concurrently -k -n web,api -c blue,magenta \"npm:dev\" \"npm:server\"",
    "dev:py": "concurrently -k -n web,api -c blue,green \"npm:dev\" \"npm:server:py\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "nodemailer": "^6.9.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "vite": "^7.0.0"
  }
}
